# Copy these values into `.env.local` for local development.
# In Vercel, add the same keys in Project Settings > Environment Variables.

# OpenAI dashboard > API keys.
# Server-side only. Do not expose this value to client components.
# Optional. Leave this blank to use the app's built-in manual seminar analysis
# and avoid API charges entirely.
OPENAI_API_KEY=sk-your-openai-api-key

# Supabase project settings > Data API > Project URL.
# Public value. Browser code can use this with the anon key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase project settings > API keys > anon public key.
# Public value. Keep Row Level Security policies enabled in Supabase.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase project settings > API keys > service_role key.
# Server-side only. This bypasses RLS and must never be imported by frontend code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Public base URL for this app, used to generate QR links.
# Local development: http://localhost:3000
# Vercel deployment: https://your-project.vercel.app
# Custom domain example: https://safety-culture.example.edu
NEXT_PUBLIC_APP_URL=http://localhost:3000
